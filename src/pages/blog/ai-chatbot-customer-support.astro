  <style is:global>
    /* Quick Verdict */
    .quick-verdict {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      background: linear-gradient(135deg, #f0f9ff, #e0f2fe);
      border: 1px solid #bae6fd;
      border-left: 4px solid var(--primary);
      border-radius: var(--radius);
      padding: 16px 20px;
      margin-bottom: 8px;
    }
    [data-theme="dark"] .quick-verdict {
      background: linear-gradient(135deg, #0c2d48, #0f3557);
      border-color: #1e4976;
      border-left-color: var(--primary);
    }
    .quick-verdict-icon {
      font-size: 20px;
      flex-shrink: 0;
      line-height: 1.5;
    }
    .quick-verdict-text {
      font-size: 15px;
      line-height: 1.6;
      color: var(--text);
    }
    .quick-verdict-text strong {
      color: var(--primary);
    }

    /* Last Updated */
    .last-updated {
      font-size: 13px;
      color: var(--text-secondary);
      margin-bottom: 24px;
    }

    /* Author Bio */
    .author-bio {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
      margin-top: 40px;
      margin-bottom: 32px;
    }
    .author-bio-avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary), var(--primary-hover));
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .author-bio-avatar span {
      color: #fff;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 0.5px;
    }
    .author-bio-content {
      flex: 1;
    }
    .author-bio-name {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 6px;
    }
    .author-bio-name strong {
      font-size: 16px;
      color: var(--text);
    }
    .author-linkedin {
      display: inline-flex;
      align-items: center;
      color: var(--text-secondary) !important;
      transition: color 0.2s;
    }
    .author-linkedin:hover {
      color: #0077b5 !important;
    }
    .author-bio-content p {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.5;
      margin: 0;
    }
  </style>
</BaseLayout>
