---
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = [
  { title: "AI Tool Pricing Compared 2026: What Do You Actually Get for Your Money", excerpt: "Pricing comparison across AI chat, writing, image, video, and coding tools. See what free tiers actually give you.", category: "AI Business", slug: "ai-tool-pricing-comparison-2026", date: "June 6, 2026", readTime: "8 min read" },
  { title: "Open Source vs Proprietary AI Models in 2026", excerpt: "Llama 4, Mistral, Qwen vs GPT-5, Claude, Gemini. Where open source has caught up and where proprietary still leads.", category: "AI Chat", slug: "open-source-vs-proprietary-ai-2026", date: "June 5, 2026", readTime: "9 min read" },
  { title: "The State of AI Coding Tools in 2026", excerpt: "From autocomplete to autonomous agents. How AI coding tools evolved and what it means for developers.", category: "AI Business", slug: "state-of-ai-coding-tools-2026", date: "June 5, 2026", readTime: "8 min read" },
  { title: "How to Automate Your Workflows with AI in 2026", excerpt: "Connect your tools with Zapier, Make, and n8n. 5 AI automations you can set up today.", category: "AI Business", slug: "how-to-automate-workflows-with-ai-2026", date: "June 6, 2026", readTime: "7 min read" },
  { title: "AI for Small Business: A Complete Guide 2026", excerpt: "Which AI tools actually save time and money for small businesses. Marketing, support, ops, and sales.", category: "AI Business", slug: "ai-for-small-business-complete-guide-2026", date: "June 6, 2026", readTime: "9 min read" },
  { title: "How to Build a Website with AI in 2026", excerpt: "From idea to live site using AI tools for design, code, content, and deployment. No coding required.", category: "AI Business", slug: "how-to-build-website-with-ai-2026", date: "June 7, 2026", readTime: "8 min read" },
  { title: "AI Prompt Engineering Guide 2026: Techniques That Actually Work", excerpt: "Practical guide to prompt engineering for ChatGPT, Claude, and Gemini. From basic to advanced strategies.", category: "AI Chat", slug: "ai-prompt-engineering-guide-2026", date: "June 7, 2026", readTime: "8 min read" },
  { title: "How to Use AI for Academic Research: A Guide for Students", excerpt: "Using AI tools like ChatGPT, Claude, Perplexity, and Elicit for literature reviews and citation management.", category: "AI Writing", slug: "how-to-use-ai-for-academic-research", date: "June 7, 2026", readTime: "7 min read" },
  { title: "Gamma vs Tome vs Beautiful.ai vs Decktopus: AI Presentation Tools Tested", excerpt: "Same presentation, four AI tools. Which actually saves you time creating slides?", category: "AI Business", slug: "ai-presentation-tools-compared-2026", date: "June 8, 2026", readTime: "7 min read" },
