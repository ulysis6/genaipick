const products = [
  { name: "Runway Gen-4", brand: "Runway", rating: "4.6", price: "12", description: "Professional AI video generation with the most creative control" },
  { name: "Sora", brand: "OpenAI", rating: "4.3", price: "20", description: "OpenAI's AI video generator included with ChatGPT Plus" },
