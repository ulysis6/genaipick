const description = "AI video is finally usable. I tested Runway, Sora, Kling, Pika, and HeyGen with the same prompt. The quality gap is real.";

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Person",
    "name": "GenAIPick Editorial"
  },
  "publisher": {
    "@type": "Organization",
    "name": "GenAIPick",
    "url": "https://genaipick.com"
  },
  "datePublished": "2026-04-05",
  "dateModified": "2026-04-05",
