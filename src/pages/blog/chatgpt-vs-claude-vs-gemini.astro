          <a href="https://chat.openai.com" class="btn btn-affiliate" target="_blank" rel="noopener sponsored">Try ChatGPT</a>
          <a href="https://claude.ai" class="btn btn-secondary" target="_blank" rel="noopener">Try Claude</a>
          <a href="https://gemini.google.com" class="btn btn-secondary" target="_blank" rel="noopener">Try Gemini</a>
        </div>
