              <td>⭐⭐⭐⭐ 3.9</td>
            </tr>
            <tr>
              <td>Ease of Use</td>
              <td>⭐⭐⭐⭐⭐ 4.7</td>
              <td>⭐⭐⭐⭐ 4.3</td>
              <td>⭐⭐⭐⭐⭐ 4.5</td>
            </tr>
            <tr>
              <td>Response Speed</td>
              <td>⭐⭐⭐⭐ 4.2</td>
              <td>⭐⭐⭐⭐ 3.8</td>
              <td>⭐⭐⭐⭐⭐ 4.6</td>
            </tr>
            <tr>
