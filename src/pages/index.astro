<BaseLayout
  title="Home"
  description="Honest, hands-on AI tool reviews and tutorials. Find the best AI tools for writing, design, business, video, and everyday use."
>
  <section class="hero">
    <div class="container">
      <h1>Find the Right AI Tool</h1>
      <p>No fluff. No sponsored reviews. Just honest, hands-on testing of the AI tools that actually matter.</p>
    </div>
  </section>
  
  <section class="clusters-section">
    <div class="container">
      <h2>Explore by Category</h2>
      <div class="clusters-grid">
        {clusters.map(cluster => (
          <a href={`/${cluster.slug}/`} class="cluster-card">
            <div class="icon">{cluster.icon}</div>
            <h3>{cluster.title}</h3>
            <p>{cluster.description}</p>
            <span class="count">{cluster.count}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
  
  <section class="articles-section">
    <div class="container">
      <h2>Latest Reviews</h2>
      <div class="articles-grid">
        {latestArticles.map(article => (
          <article class="article-card">
            <div class="content">
              <span class="category">{article.category}</span>
              <h3><a href={`/blog/${article.slug}/`}>{article.title}</a></h3>
              <p>{article.excerpt}</p>
              <div class="meta">
                <span>{article.date}</span>
                <span>{article.readTime}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/blog/" class="btn btn-primary">View All Articles</a>
      </div>
    </div>
  </section>
</BaseLayout>
