---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Terms of Service",
  "description": "GenAIPick terms of service - the rules for using this website.",
  "url": "https://genaipick.com/terms/"

import AffiliateBanner from '../components/AffiliateBanner.astro';});
---

<BaseLayout
  title="Terms of Service"
  description="Terms of service for GenAIPick. Read the terms before using this website."
  structuredData={structuredData}
>
  <div class="static-page">
    <div class="container">
      <div class="static-content">
        <h1>Terms of Service</h1>
        
        <p><strong>Last updated: February 2026</strong></p>

  <AffiliateBanner variant="compact" />


        
        <p>By using GenAIPick, you agree to these terms. If you don't agree, please don't use this website.</p>
        
        <h2>Website Use</h2>
        
        <p>You may use this website for personal, non-commercial purposes. You may not:</p>
        <ul>
          <li>Republish content from this site without attribution</li>
          <li>Use automated tools to scrape or copy content</li>
          <li>Impersonate this website or its author</li>
          <li>Use this site for any illegal purpose</li>
        </ul>
        
        <h2>Content Accuracy</h2>
        
        <p>I strive for accuracy, but this website is provided "as is." I don't guarantee that all information is current, complete, or error-free. AI tools change rapidly, and some information may become outdated.</p>
        
        <p>Reviews and opinions are my own. I'm not a professional reviewer or journalist - just someone who uses these tools and shares my experiences.</p>
        
        <h2>Recommendations and Advice</h2>
        
        <p>Content on this site is not professional advice. My reviews reflect my personal experiences and opinions. What works for me might not work for you. Always do your own research before making purchasing decisions.</p>
        
        <h2>Affiliate Links</h2>
        
        <p>This website contains affiliate links. If you click an affiliate link and make a purchase, I may earn a commission at no additional cost to you. This does not influence my reviews or recommendations in any way.</p>
        
        <h2>Third-Party Content</h2>
        
        <p>This site may link to third-party websites. I'm not responsible for content, products, or services provided by external sites. Visit third-party sites at your own risk.</p>
        
        <h2>Intellectual Property</h2>
        
        <p>All original content on this site is my intellectual property. You may share links to this content freely. If you want to republish or reuse content, please contact me first.</p>
        
        <h2>Limitation of Liability</h2>
        
        <p>I'm not liable for any damages arising from your use of this website. This includes, but is not limited to, direct, indirect, incidental, or consequential damages.</p>
        
        <h2>Changes to Terms</h2>
        
        <p>I may update these terms at any time. Continued use of this website after changes constitutes acceptance of the new terms.</p>
        
        <h2>Governing Law</h2>
        
        <p>These terms are governed by applicable laws. Any disputes will be resolved according to the laws of the jurisdiction.</p>
        
        <h2>Contact</h2>
        
        <p>Questions about these terms? Contact me at: <strong><a href="mailto:hello@genaipick.com">hello@genaipick.com</a></strong></p>
      </div>
    </div>
  </div>
</BaseLayout>
